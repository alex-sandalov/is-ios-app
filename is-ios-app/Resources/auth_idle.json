{
  "root": {
    "id": "auth_root",
    "type": "scroll",
    "content": {
      "spacing": "l",
      "padding": "m",
      "backgroundColor": "background"
    },
    "subviews": [
      {
        "id": "auth_header_card",
        "type": "card",
        "content": {
          "padding": "m",
          "backgroundColor": "elevatedSurface"
        },
        "subviews": [
          {
            "id": "auth_header_stack",
            "type": "vStack",
            "content": {
              "spacing": "m",
              "padding": "xs",
              "backgroundColor": "clear"
            },
            "subviews": [
              {
                "id": "auth_brand_badge",
                "type": "container",
                "content": {
                  "backgroundColor": "surface",
                  "padding": "xs",
                  "cornerRadius": "m"
                },
                "subviews": [
                  {
                    "id": "auth_brand_badge_text",
                    "type": "label",
                    "content": {
                      "text": "DIGITAL BANKING",
                      "textStyle": "captionSecondary",
                      "color": "primary",
                      "alignment": "left",
                      "numberOfLines": 1
                    }
                  }
                ]
              },
              {
                "id": "auth_brand_title",
                "type": "label",
                "content": {
                  "text": "Beta-Bank",
                  "textStyle": "largeTitle",
                  "color": "primary",
                  "alignment": "left",
                  "numberOfLines": 1
                }
              },
              {
                "id": "auth_brand_subtitle",
                "type": "label",
                "content": {
                  "text": "Управляй продуктами быстро, удобно и в одном месте.",
                  "textStyle": "bodySecondary",
                  "color": "textSecondary",
                  "alignment": "left",
                  "numberOfLines": 0
                }
              }
            ]
          }
        ]
      },
      {
        "id": "auth_form_card",
        "type": "card",
        "content": {
          "padding": "m",
          "backgroundColor": "surface"
        },
        "subviews": [
          {
            "id": "auth_form_stack",
            "type": "vStack",
            "content": {
              "spacing": "m",
              "padding": "xs",
              "backgroundColor": "clear"
            },
            "subviews": [
              {
                "id": "auth_form_title",
                "type": "label",
                "content": {
                  "text": "Авторизация",
                  "textStyle": "title",
                  "color": "textPrimary",
                  "alignment": "left",
                  "numberOfLines": 1
                }
              },
              {
                "id": "auth_form_subtitle",
                "type": "label",
                "content": {
                  "text": "Введи логин и пароль, чтобы продолжить.",
                  "textStyle": "bodySecondary",
                  "color": "textSecondary",
                  "alignment": "left",
                  "numberOfLines": 0
                }
              },
              {
                "id": "auth_login_field",
                "type": "textField",
                "content": {
                  "placeholder": "Введите логин",
                  "title": "Логин",
                  "text": null,
                  "errorMessage": null,
                  "isSecure": false
                }
              },
              {
                "id": "auth_password_field",
                "type": "textField",
                "content": {
                  "placeholder": "Введите пароль",
                  "title": "Пароль",
                  "text": null,
                  "errorMessage": null,
                  "isSecure": true
                }
              },
              {
                "id": "auth_login_button",
                "type": "button",
                "content": {
                  "title": "Войти",
                  "style": "primary",
                  "isEnabled": true
                },
                "action": {
                  "type": "callback",
                  "id": "auth_login_tap"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "auth_bottom_space",
        "type": "spacer",
        "content": {
          "height": 220
        }
      }
    ]
  }
}
